{
  "name": "document-translation-web",
  "version": "0.1.0",
  "description": "Document Translation Web App",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "npx ts-node --project tsconfig.server.json server/index.ts",
    "client": "vite",
    "build": "vite build && npx tsc -p tsconfig.server.json",
    "start": "node dist-server/index.js",
    "preview": "vite preview"
  },
  "dependencies": {
    "@azure/ai-form-recognizer": "^4.0.0",
    "@azure/core-auth": "^1.7.0",
    "cors": "^2.8.5",
    "docx": "^8.5.0",
    "express": "^4.19.0",
    "multer": "^1.4.5-lts.1",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.4.168",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  }
}
